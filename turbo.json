{
  "$schema": "https://turbo.build/schema.json",
  "envMode": "strict",
  "globalEnv": [
    "CI",
    "NODE_ENV",
    "AUTH_*",
    "NEXTAUTH_*",
    "USE_DEVELOPMENT_*",
    "SQLITE_FILE",
    "DATABASE_URL",
    "TURSO_URL",
    "TURSO_TOKEN",
    "MASTER_EMAIL",
    "EMAIL_FROM",
    "RESEND_SECRET",
    "UPLOADTHING_SECRET",
    "VERCEL_BLOB_API_URL",
    "NEXT_PUBLIC_VERCEL_BLOB_API_URL"
  ],
  "globalDependencies": [
    ".github/workflows/**",
    "pnpm-workspace.yaml",
    "pnpm-lock.yaml",
    "package.json",
    "tsconfig.json"
  ],
  "tasks": {
    "prebuild": {
      "dependsOn": ["^wait"],
      "inputs": ["$TURBO_DEFAULT$", ".env*", ".oberon/**"],
      "env": [
        "NODE_ENV",
        "AUTH_*",
        "NEXTAUTH_*",
        "USE_DEVELOPMENT_DATABASE",
        "USE_DEVELOPMENT_SEND",
        "SQLITE_FILE",
        "DATABASE_URL",
        "TURSO_URL",
        "TURSO_TOKEN",
        "MASTER_EMAIL",
        "EMAIL_FROM",
        "RESEND_SECRET",
        "UPLOADTHING_SECRET",
        "VERCEL_BLOB_API_URL",
        "NEXT_PUBLIC_VERCEL_BLOB_API_URL"
      ]
    },
    "build": {
      "dependsOn": ["wait:clean", "^build", "prebuild"],
      "inputs": ["$TURBO_DEFAULT$", ".env*", ".oberon/**", "plugins/**"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NODE_ENV",
        "AUTH_*",
        "NEXTAUTH_*",
        "USE_DEVELOPMENT_DATABASE",
        "USE_DEVELOPMENT_SEND",
        "SQLITE_FILE",
        "DATABASE_URL",
        "TURSO_URL",
        "TURSO_TOKEN",
        "MASTER_EMAIL",
        "EMAIL_FROM",
        "RESEND_SECRET",
        "UPLOADTHING_SECRET",
        "VERCEL_BLOB_API_URL",
        "NEXT_PUBLIC_VERCEL_BLOB_API_URL"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["wait:clean", "^wait", "prebuild"],
      "env": [
        "NODE_ENV",
        "AUTH_*",
        "NEXTAUTH_*",
        "USE_DEVELOPMENT_DATABASE",
        "USE_DEVELOPMENT_SEND",
        "SQLITE_FILE",
        "DATABASE_URL",
        "TURSO_URL",
        "TURSO_TOKEN",
        "MASTER_EMAIL",
        "EMAIL_FROM",
        "RESEND_SECRET",
        "UPLOADTHING_SECRET",
        "VERCEL_BLOB_API_URL",
        "NEXT_PUBLIC_VERCEL_BLOB_API_URL"
      ]
    },

    "start": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["build"],
      "env": [
        "NODE_ENV",
        "AUTH_*",
        "NEXTAUTH_*",
        "USE_DEVELOPMENT_DATABASE",
        "USE_DEVELOPMENT_SEND",
        "SQLITE_FILE",
        "DATABASE_URL",
        "TURSO_URL",
        "TURSO_TOKEN",
        "MASTER_EMAIL",
        "EMAIL_FROM",
        "RESEND_SECRET",
        "UPLOADTHING_SECRET",
        "VERCEL_BLOB_API_URL",
        "NEXT_PUBLIC_VERCEL_BLOB_API_URL"
      ]
    },
    "check": {
      "dependsOn": ["lint", "tsc", "test:unit"]
    },
    "clean": {
      "cache": false
    },
    "generate:migrations": {
      "cache": false
    },
    "generate:recipes": {
      "cache": false
    },
    "test:unit": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "outputs": [".playwright"]
    },
    "test:coa": {
      "dependsOn": ["build"],
      "outputs": [".playwright"]
    },
    "test:coa:ui": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["build"],
      "outputs": []
    },
    "test:smoke": {
      "dependsOn": [],
      "outputs": [".playwright"],
      "env": ["PLAYWRIGHT_BASE_URL", "VERCEL_PROTECTION_BYPASS"]
    },
    "test:ui": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["build"],
      "outputs": []
    },
    "test:watch": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "lint": {
      "outputs": []
    },
    "tsc": {
      "dependsOn": ["^build"]
    },
    "//#tsc:root": {},
    "wait": {},
    "wait:clean": {},
    "prepublishOnly": {
      "dependsOn": ["build"]
    }
  }
}
