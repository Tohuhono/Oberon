{
  "$schema": "https://turbo.build/schema.json",
  "envMode": "strict",
  "remoteCache": { "enabled": false },
  "globalEnv": [
    "CI",
    "NODE_ENV",
    "AUTH_*",
    "NEXTAUTH_*",
    "USE_DEVELOPMENT_*",
    "SQLITE_FILE",
    "DATABASE_URL",
    "TURSO_URL",
    "TURSO_TOKEN",
    "MASTER_EMAIL",
    "EMAIL_FROM",
    "RESEND_SECRET",
    "UPLOADTHING_SECRET",
    "VERCEL_BLOB_API_URL",
    "NEXT_PUBLIC_VERCEL_BLOB_API_URL"
  ],
  "globalDependencies": [".github/workflows/**"],
  "futureFlags": {
    "watchUsingTaskInputs": true,
    "errorsOnlyShowHash": true
  },
  "tasks": {
    "prebuild": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*",
        "!.oberon/**",
        "!.turbo/**",
        "!.next/**",
        "!.playwright/**"
      ],
      "outputs": [".oberon/**"],
      "env": [
        "NODE_ENV",
        "AUTH_*",
        "NEXTAUTH_*",
        "USE_DEVELOPMENT_DATABASE",
        "USE_DEVELOPMENT_SEND",
        "SQLITE_FILE",
        "DATABASE_URL",
        "TURSO_URL",
        "TURSO_TOKEN",
        "MASTER_EMAIL",
        "EMAIL_FROM",
        "RESEND_SECRET",
        "UPLOADTHING_SECRET",
        "VERCEL_BLOB_API_URL",
        "NEXT_PUBLIC_VERCEL_BLOB_API_URL"
      ]
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*",
        ".oberon/**",
        "plugins/**",
        "!.turbo/**",
        "!.next/**",
        "!.playwright/**"
      ],
      "outputs": [".next/**", "dist/**", "!.next/cache/**", "!.next/types/**"],
      "env": [
        "NODE_ENV",
        "AUTH_*",
        "NEXTAUTH_*",
        "USE_DEVELOPMENT_DATABASE",
        "USE_DEVELOPMENT_SEND",
        "SQLITE_FILE",
        "DATABASE_URL",
        "TURSO_URL",
        "TURSO_TOKEN",
        "MASTER_EMAIL",
        "EMAIL_FROM",
        "RESEND_SECRET",
        "UPLOADTHING_SECRET",
        "VERCEL_BLOB_API_URL",
        "NEXT_PUBLIC_VERCEL_BLOB_API_URL"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["wait:clean", "^wait", "prebuild"],
      "env": [
        "NODE_ENV",
        "AUTH_*",
        "NEXTAUTH_*",
        "USE_DEVELOPMENT_DATABASE",
        "USE_DEVELOPMENT_SEND",
        "SQLITE_FILE",
        "DATABASE_URL",
        "TURSO_URL",
        "TURSO_TOKEN",
        "MASTER_EMAIL",
        "EMAIL_FROM",
        "RESEND_SECRET",
        "UPLOADTHING_SECRET",
        "VERCEL_BLOB_API_URL",
        "NEXT_PUBLIC_VERCEL_BLOB_API_URL"
      ]
    },
    "start": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["build"],
      "env": [
        "NODE_ENV",
        "AUTH_*",
        "NEXTAUTH_*",
        "USE_DEVELOPMENT_DATABASE",
        "USE_DEVELOPMENT_SEND",
        "SQLITE_FILE",
        "DATABASE_URL",
        "TURSO_URL",
        "TURSO_TOKEN",
        "MASTER_EMAIL",
        "EMAIL_FROM",
        "RESEND_SECRET",
        "UPLOADTHING_SECRET",
        "VERCEL_BLOB_API_URL",
        "NEXT_PUBLIC_VERCEL_BLOB_API_URL"
      ]
    },
    "check": {
      "dependsOn": ["lint", "tsc", "test:unit"]
    },
    "clean": {
      "cache": false
    },
    "generate:migrations": {
      "cache": false
    },
    "generate:recipes": {
      "cache": false
    },
    "test:unit": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*",
        "!.oberon/**",
        "!.turbo/**",
        "!.next/**",
        "!.playwright/**"
      ]
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*",
        "!.oberon/**",
        "!.turbo/**",
        "!.next/**",
        "!.playwright/**"
      ],
      "outputs": [".playwright"]
    },
    "test:e2e:ui": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["build"],
      "outputs": []
    },
    "test:coa": {
      "dependsOn": ["build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*",
        "!.oberon/**",
        "!.turbo/**",
        "!.next/**",
        "!.playwright/**"
      ],
      "outputs": [".playwright"]
    },
    "test:coa:ui": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["build"],
      "outputs": []
    },
    "test:smoke": {
      "dependsOn": [],
      "outputs": [".playwright"],
      "env": ["PLAYWRIGHT_BASE_URL", "VERCEL_PROTECTION_BYPASS"]
    },
    "test:tdd": {
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*",
        "!.oberon/**",
        "!.turbo/**",
        "!.next/**",
        "!.playwright/**"
      ],
      "dependsOn": ["build"],
      "outputs": [".playwright"]
    },
    "test:tdd:ui": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["build"],
      "outputs": []
    },
    "test:watch": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "lint": {
      "outputs": []
    },
    "tsc": {
      "dependsOn": ["typegen"],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*",
        "!.oberon/**",
        "!.turbo/**",
        "!.next/**",
        "!.playwright/**"
      ],
      "outputs": []
    },
    "typegen": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*",
        "!.oberon/**",
        "!.turbo/**",
        "!.next/**",
        "!.playwright/**"
      ],
      "outputs": [".next/types/**", "next-env.d.ts"]
    },
    "wait": {
      "cache": false,
      "outputs": []
    },
    "wait:clean": {
      "cache": false,
      "outputs": []
    },
    "prepublishOnly": {
      "dependsOn": ["build"]
    },
    "validate": {
      "dependsOn": ["lint", "tsc", "test:unit", "test:e2e", "test:coa"]
    }
  }
}
