{
  "name": "oberon",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo build --concurrency 50",
    "build:packages": "turbo build --concurrency 50 --filter={./packages/**/*}...",
    "build:docs": "turbo build --concurrency 50 --filter=@oberon/docs...",
    "build:oberon": "turbo build --concurrency 50 --filter=@oberon/playground...",
    "build:nextjs": "turbo build --concurrency 50 --filter=@oberon/recipe-nextjs...",
    "build:tanstack": "turbo build --concurrency 50 --filter=@oberon/recipe-tanstack...",
    "build:coa": "turbo build --concurrency 50 --filter=create-oberon-app... && turbo generate:recipes",
    "change": "changeset",
    "check": "USE_DEVELOPMENT_DATABASE=true USE_DEVELOPMENT_SEND=true turbo check --concurrency 50 --output-logs errors-only",
    "clean": "turbo clean --continue && odt clean",
    "clean:next": "turbo clean --continue -- --only ./.next",
    "clean:node": "pnpm clean && rimraf --glob ./**/node_modules",
    "clean:e2e": "rimraf --glob ./**/.orberon/e2e*ss",
    "deploy": "bash ./dev/scripts/scripts/deploy.sh",
    "dev": "turbo dev --concurrency 50",
    "dev:docs": "turbo dev --concurrency 50 --filter=@oberon/docs...",
    "dev:nextjs": "turbo dev --concurrency 50 --filter=@oberon/recipe-nextjs...",
    "dev:tanstack": "turbo dev --concurrency 50 --filter=@oberon/recipe-tanstack...",
    "dev:oberon": "turbo dev --concurrency 50 --continue --filter=@oberon/playground...",
    "dev:packages": "turbo dev --concurrency 50 --filter={./packages/**/*}...",
    "format": "oxfmt \"**/*.{ts,tsx,js,jsx,css,md,mdx,json}\"",
    "format:check": "oxfmt --check \"**/*.{ts,tsx,js,jsx,css,md,mdx,json}\"",
    "generate:migrations": "turbo generate:migrations",
    "lint": "turbo lint --concurrency 50",
    "lint:fix": "turbo lint --concurrency 50 -- --fix",
    "lint:root": "oxlint",
    "manypkg": "manypkg check",
    "manypkg:fix": "manypkg fix",
    "postinstall": "pnpm manypkg",
    "prepare": "husky",
    "release": "pnpm build:packages && changeset publish",
    "start:nextjs": "turbo start --concurrency 50 --filter=@oberon/recipe-nextjs",
    "start:oberon": "turbo start --concurrency 50 --filter=@oberon/playground",
    "start:docs": "turbo start --concurrency 50 --filter=@oberon/docs",
    "tsc": "turbo run tsc --concurrency 50 --continue",
    "test": "turbo test:unit test:e2e --concurrency 50",
    "test:coa": "turbo test:coa --concurrency 50 --filter=create-oberon-app... --output-logs new-only",
    "test:coa:ui": "turbo test:coa:ui --concurrency 50 --filter=create-oberon-app... --output-logs new-only",
    "test:e2e": "turbo test:e2e --filter={./apps/*}... --concurrency 50 --output-logs errors-only",
    "test:e2e:ui": "turbo test:e2e:ui --concurrency 50",
    "test:unit": "turbo test:unit --filter={./packages/tohuhono/*}... --filter={./packages/plugins/*}... --filter={./packages/oberoncms/*}... --concurrency 50 ",
    "test:watch": "turbo test:watch --filter={./packages/*}... --concurrency 50",
    "test:tdd": "turbo test:tdd --concurrency 50 --filter=@oberon/playground... --output-logs new-only",
    "test:tdd:ui": "turbo test:tdd:ui --concurrency 50 --filter=@oberon/playground...",
    "test:smoke": "turbo test:smoke --concurrency 50",
    "validate": "turbo validate --concurrency 50 --output-logs new-only"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@dev/oxlint": "workspace:*",
    "@dev/scripts": "workspace:*",
    "@dev/typescript": "workspace:*",
    "@manypkg/cli": "^0.25.1",
    "@tailwindcss/postcss": "^4.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "neonctl": "^2.22.0",
    "oxfmt": "^0.51.0",
    "rimraf": "^6.1.2",
    "turbo": "^2.8.20",
    "typescript": "5.9.3",
    "vercel": "^52.0.0",
    "wait-on": "^9.0.4"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,css,md,json}": "oxfmt"
  },
  "engines": {
    "node": ">=24.13.0",
    "npm": "please-use-pnpm",
    "pnpm": ">=10.0.0",
    "yarn": "please-use-pnpm"
  },
  "packageManager": "pnpm@10.27.0",
  "pnpm": {
    "overrides": {
      "zod-validation-error": "^4.0.0"
    },
    "patchedDependencies": {
      "nextra": "patches/nextra.patch",
      "@vitest/runner": "patches/@vitest__runner.patch"
    }
  },
  "manypkg": {
    "ignoredRules": [
      "INTERNAL_MISMATCH"
    ]
  }
}
