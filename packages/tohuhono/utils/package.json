{
  "name": "@tohuhono/utils",
  "version": "0.14.2",
  "author": "Tohuhono ltd",
  "license": "MIT",
  "description": "A collection of utility functions used by @tohuhono and @oberoncms packages",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tohuhono/Oberon",
    "directory": "packages/tohuhono/utils"
  },
  "type": "module",
  "scripts": {
    "build": "vite build",
    "clean": "odt clean",
    "dev": "vite build --watch",
    "wait": "wait-on ./dist/version && echo done",
    "wait:clean": "rimraf ./dist/version",
    "lint": "eslint .",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "tsc": "tsc --pretty"
  },
  "exports": {
    ".": "./dist/index.js",
    "./exec-async": {
      "types": "./src/exec-async.ts",
      "default": "./dist/exec-async.js"
    },
    "./map-concurrent": "./dist/map-concurrent.js",
    "./use-client-state": "./dist/use-client-state.js",
    "./use-local-storage": "./dist/use-local-storage.js",
    "./use-mode": "./dist/use-mode.js",
    "./wait-for-server": {
      "types": "./src/wait-for-server.ts",
      "default": "./dist/wait-for-server.js"
    }
  },
  "files": [
    "dist",
    "src",
    "CHANGELOG*",
    "README*",
    "LICENSE*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "tailwind-merge": "^3.4.1"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@dev/eslint": "workspace:*",
    "@dev/scripts": "workspace:*",
    "@dev/typescript": "workspace:*",
    "@dev/vite": "workspace:*",
    "@dev/vitest": "workspace:*",
    "@types/node": "24.10.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "5.9.3"
  }
}
