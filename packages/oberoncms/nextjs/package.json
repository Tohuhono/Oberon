{
  "name": "@oberoncms/nextjs",
  "version": "0.1.1",
  "private": true,
  "files": [
    "dist",
    "src",
    "CHANGELOG*",
    "README*",
    "LICENSE*"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "vite build",
    "clean": "odt clean",
    "dev": "vite build --watch",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "tsc": "tsc --pretty",
    "wait": "wait-on ./dist/version && echo done",
    "wait:clean": "rimraf ./dist/version"
  },
  "dependencies": {
    "@oberoncms/core": "workspace:*"
  },
  "devDependencies": {
    "@dev/oxlint": "workspace:*",
    "@dev/scripts": "workspace:*",
    "@dev/typescript": "workspace:*",
    "@dev/vite": "workspace:*",
    "@dev/vitest": "workspace:*",
    "@types/node": "24.10.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "5.9.3"
  }
}
