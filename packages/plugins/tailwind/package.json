{
  "name": "@oberoncms/plugin-tailwind",
  "version": "0.20.0",
  "description": "A dynamic Tailwind utilities plugin for OberonCMS",
  "keywords": [
    "adapter",
    "cms",
    "nextjs",
    "oberon",
    "oberoncms",
    "plugin",
    "react",
    "tailwind"
  ],
  "license": "MIT",
  "author": "Tohuhono ltd",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tohuhono/Oberon",
    "directory": "packages/plugins/tailwind"
  },
  "files": [
    "dist",
    "src",
    "CHANGELOG*",
    "README*",
    "LICENSE*"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "clean": "odt clean",
    "dev": "vite build --watch",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "tsc": "tsc --pretty",
    "wait": "wait-on ./dist/version && echo done",
    "wait:clean": "rimraf ./dist/version"
  },
  "dependencies": {
    "@oberoncms/core": "workspace:*",
    "@tailwindcss/node": "^4.2.1",
    "server-cli-only": "^0.3.2",
    "walkjs": "^6.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@dev/oxlint": "workspace:*",
    "@dev/scripts": "workspace:*",
    "@dev/typescript": "workspace:*",
    "@dev/vite": "workspace:*",
    "@dev/vitest": "workspace:*",
    "@oberoncms/sqlite": "workspace:*",
    "@oberoncms/testing": "workspace:*",
    "@types/node": "24.10.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
