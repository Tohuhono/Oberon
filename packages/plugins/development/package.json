{
  "name": "@oberoncms/plugin-development",
  "version": "0.8.1",
  "description": "A development plugin for OberonCMS",
  "keywords": [
    "adapter",
    "cms",
    "nextjs",
    "oberon",
    "oberoncms",
    "plugin",
    "react"
  ],
  "license": "MIT",
  "author": "Tohuhono ltd",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tohuhono/Oberon",
    "directory": "packages/plugins/development"
  },
  "files": [
    "dist",
    "src",
    "CHANGELOG*",
    "README*",
    "LICENSE*"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "clean": "odt clean",
    "generate:migrations": "drizzle-kit generate",
    "dev": "vite build --watch",
    "lint": "eslint .",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "tsc": "tsc --pretty",
    "wait": "wait-on ./dist/version && echo done",
    "wait:clean": "rimraf ./dist/version"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@libsql/core": "^0.17.0",
    "@oberoncms/core": "workspace:*",
    "@oberoncms/sqlite": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "next": "^16.1.6",
    "server-cli-only": "^0.3.2"
  },
  "devDependencies": {
    "@dev/eslint": "workspace:*",
    "@dev/scripts": "workspace:*",
    "@dev/typescript": "workspace:*",
    "@dev/vite": "workspace:*",
    "@dev/vitest": "workspace:*",
    "@oberoncms/testing": "workspace:*",
    "@puckeditor/core": "^0.21.1",
    "@types/node": "24.10.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "^0.31.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
